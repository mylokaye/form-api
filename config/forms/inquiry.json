{
  "version": "1.0",
  "rules": [
    {
      "id": "state_visibility",
      "type": "visibility",
      "field": "nor_state",
      "condition": {
        "field": "nor_country",
        "op": "eq",
        "value": "United States"
      },
      "actions": [
        { "type": "set_visible", "value": true }
      ]
    },
    {
      "id": "division_hide_on_simpson",
      "type": "visibility",
      "field": "nor_division",
      "condition": {
        "field": "_hostname",
        "op": "contains",
        "value": "simpsongroup.com"
      },
      "actions": [
        { "type": "set_visible", "value": false }
      ]
    },
    {
      "id": "category_options",
      "type": "static_options",
      "field": "nor_noricansalescategory",
      "values": [
        "Aftermarket",
        "OEM",
        "EMP"
      ]
    },
    {
      "id": "process_options_filter",
      "type": "options_filter",
      "field": "nor_noricansalesprocess",
      "depends_on": "nor_noricansalescategory",
      "mapping": {
        "Aftermarket": ["Monitizer", "New Business", "Upgrade/Retrofit", "Spares & Service"],
        "OEM": ["Monitizer", "New Business", "Upgrade/Retrofit", "Spares & Service"],
        "EMP": ["Monitizer", "New Business", "Upgrade/Retrofit", "Spares & Service"]
      }
    },
    {
      "id": "division_options",
      "type": "static_options",
      "field": "nor_division",
      "values": [
        "SIMPSON",
        "DISA",
        "StrikoWestofen",
        "Wheelabrator"
      ]
    },
    {
      "id": "language_by_browser",
      "type": "field_value_map",
      "field": "nor_primarylanguage",
      "source": "_language",
      "defaultValue": "English",
      "mapping": [
        { "match": "ar", "value": "Arabic" },
        { "match": "eu", "value": "Basque" },
        { "match": "bg", "value": "Bulgarian" },
        { "match": "ca", "value": "Catalan" },
        { "match": "zh", "value": "Chinese" },
        { "match": "hr", "value": "Croatian" },
        { "match": "cs", "value": "Czech" },
        { "match": "da", "value": "Danish" },
        { "match": "nl", "value": "Dutch" },
        { "match": "en", "value": "English" },
        { "match": "et", "value": "Estonian" },
        { "match": "fi", "value": "Finnish" },
        { "match": "fr", "value": "French" },
        { "match": "gl", "value": "Galician" },
        { "match": "de", "value": "German" },
        { "match": "el", "value": "Greek" },
        { "match": "he", "value": "Hebrew" },
        { "match": "hi", "value": "Hindi" },
        { "match": "hu", "value": "Hungarian" },
        { "match": "id", "value": "Indonesian" },
        { "match": "it", "value": "Italian" },
        { "match": "ja", "value": "Japanese" },
        { "match": "kk", "value": "Kazakh" },
        { "match": "ko", "value": "Korean" },
        { "match": "lv", "value": "Latvian" },
        { "match": "lt", "value": "Lithuanian" },
        { "match": "ms", "value": "Malay" },
        { "match": "nb", "value": "Norwegian" },
        { "match": "no", "value": "Norwegian" },
        { "match": "pl", "value": "Polish" },
        { "match": "pt", "value": "Portuguese" },
        { "match": "ro", "value": "Romanian" },
        { "match": "ru", "value": "Russian" },
        { "match": "sr", "value": "Serbian" },
        { "match": "sk", "value": "Slovak" },
        { "match": "sl", "value": "Slovenian" },
        { "match": "es", "value": "Spanish" },
        { "match": "sv", "value": "Swedish" },
        { "match": "th", "value": "Thai" },
        { "match": "tr", "value": "Turkish" },
        { "match": "uk", "value": "Ukrainian" },
        { "match": "vi", "value": "Vietnamese" }
      ]
    },
    {
      "id": "division_by_hostname",
      "type": "field_value_map",
      "field": "nor_division",
      "source": "_hostname",
      "mapping": [
        { "match": "simpsongroup.com", "value": "SIMPSON" },
        { "match": "disagroup.com", "value": "DISA" },
        { "match": "disa-india.com", "value": "DISA" },
        { "match": "strikowestofen.com", "value": "StrikoWestofen" },
        { "match": "wheelabratorgroup.com", "value": "Wheelabrator" },
                { "match": "mylokaye.info", "value": "Wheelabrator" }

      ]
    },
    {
  "id": "hide_phone_on_mylokaye",
  "type": "visibility",
  "field": "mobilephone",
  "condition": {
    "field": "_hostname",
    "op": "contains",
    "value": "mylokaye.info"
  },
  "actions": [
    { "type": "set_visible", "value": false }
  ]
}
  ]
}
