{
  "version": "1.0",
  "rules": [
    {
      "id": "state_visibility",
      "type": "visibility",
      "field": "nor_state",
      "condition": {
        "field": "nor_country",
        "op": "eq",
        "value": "United States"
      },
      "actions": [
        { "type": "set_visible", "value": true }
      ]
    },
    {
      "id": "division_hide_on_simpson",
      "type": "visibility",
      "field": "nor_division",
      "condition": {
        "field": "_hostname",
        "op": "contains",
        "value": "simpsongroup.com"
      },
      "actions": [
        { "type": "set_visible", "value": false }
      ]
    },
    {
      "id": "process_options_filter",
      "type": "options_filter",
      "field": "nor_noricansalesprocess",
      "depends_on": "nor_noricansalescategory",
      "mapping": {
        "Equipment": ["New Equipment", "Service", "Parts"],
        "Service": ["Repair", "Maintenance", "Consulting"]
      }
    },
    {
      "id": "division_options",
      "type": "static_options",
      "field": "nor_division",
      "values": [
        "SIMPSON",
        "DISA",
        "StrikoWestofen",
        "Wheelabrator"
      ]
    },
    {
      "id": "division_by_hostname",
      "type": "field_value_map",
      "field": "nor_division",
      "source": "_hostname",
      "mapping": [
        { "match": "simpsongroup.com", "value": "SIMPSON" },
        { "match": "disagroup.com", "value": "DISA" },
        { "match": "disa-india.com", "value": "DISA" },
        { "match": "strikowestofen.com", "value": "StrikoWestofen" },
        { "match": "wheelabratorgroup.com", "value": "Wheelabrator" }
      ]
    },
    {
  "id": "hide_phone_on_mylokaye",
  "type": "visibility",
  "field": "mobilephone",
  "condition": {
    "field": "_hostname",
    "op": "contains",
    "value": "mylokaye.info"
  },
  "actions": [
    { "type": "set_visible", "value": false }
  ]
}
  ]
}
